{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "shared-stack": {
      "projectType": "library",
      "root": "projects/shared-stack",
      "sourceRoot": "projects/shared-stack/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/shared-stack/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/shared-stack/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/shared-stack/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/shared-stack/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "b57c5e9b-0f79-433b-bc5f-2476afd1525a"
  }
}
